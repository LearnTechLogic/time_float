<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.time_float_backend.mapper.ReplyMapper">

    <resultMap id="ReplyResultMap" type="com.time_float_backend.entity.Reply">
        <id property="id" column="id"/>
        <result property="bottleId" column="bottle_id"/>
        <result property="fromUserId" column="from_user_id"/>
        <result property="toUserId" column="to_user_id"/>
        <result property="content" column="content"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="fromUsername" column="from_username"/>
        <result property="toUsername" column="to_username"/>
    </resultMap>

    <insert id="insert" parameterType="com.time_float_backend.entity.Reply" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO replies (bottle_id, from_user_id, to_user_id, content)
        VALUES (#{bottleId}, #{fromUserId}, #{toUserId}, #{content})
    </insert>

    <select id="findByBottleId" resultMap="ReplyResultMap">
        SELECT r.*, u1.username as from_username, u2.username as to_username
        FROM replies r
        LEFT JOIN users u1 ON r.from_user_id = u1.id
        LEFT JOIN users u2 ON r.to_user_id = u2.id
        WHERE r.bottle_id = #{bottleId}
        ORDER BY r.created_at ASC
    </select>

</mapper>
